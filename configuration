############################################
# Enterprise Departmental Network
# MikroTik Configuration
# Author: Sawjon Barikder
############################################

############################################
# INTERFACE CONFIGURATION
############################################

/interface ethernet
set [ find default-name=ether1 ] name=WAN
set [ find default-name=ether2 ] name=HR-Network
set [ find default-name=ether3 ] name=IT-Network
set [ find default-name=ether8 ] name=Mail-Server

############################################
# IP ADDRESSING
############################################

/ip address
add address=172.168.110.1/24 comment="to HR" interface=ether2 network=\
    172.168.110.0
add address=172.168.120.1/24 comment="to IT" interface=ether3 network=\
    172.168.120.0
add address=172.168.200.1/30 comment="to server" interface=ether8 network=\
    172.168.200.0

############################################
# DHCP CONFIGURATION
############################################

/ip pool
add name=IT-pool ranges=172.168.120.10-172.168.120.200
add name=hr-pool ranges=172.168.110.10-172.168.110.100
/ip dhcp-server
add address-pool=hr-pool disabled=no interface=ether2 name=hr-dhcp
add address-pool=IT-pool disabled=no interface=ether3 name=it-dhcp

/ip dhcp-client
add disabled=no interface=ether1
/ip dhcp-server network
add address=172.168.110.0/24 dns-server=8.8.8.8 gateway=172.168.110.1
add address=172.168.120.0/24 dns-server=8.8.8.8 gateway=172.168.120.1

############################################
# NAT CONFIGURATION
############################################

/ip firewall nat
add action=masquerade chain=srcnat comment="for INT reachability" \
    out-interface=ether1

############################################
# FIREWALL RULES
############################################

/ip firewall filter
add action=accept chain=forward comment="hr to mail" dst-address=\
    172.168.200.2 src-address=192.168.110.0/24
add action=accept chain=forward comment="it to mail" dst-address=\
    172.168.200.2 src-address=192.168.120.0/24
add action=drop chain=forward comment="block hr-it" dst-address=\
    172.168.120.0/24 src-address=172.168.110.0/24
add action=drop chain=forward comment="block it - hr" dst-address=\
    172.168.110.0/24 src-address=172.168.120.0/24

############################################
# DNS CONFIGURATION
############################################

/ip dns
set servers=8.8.8.8 allow-remote-requests=yes
